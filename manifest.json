{
  "manifest_version": 3,
  "name": "betterGPT",
  "description": "betterGPT reduces lag on long ChatGPT threads by virtualizing older messages.",
  "version": "1.0.0",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://chatgpt.com/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "content_script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "betterGPT",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16x16_off.png",
      "48": "icons/48x48_off.png",
      "128": "icons/128x128_off.png"
    }
  },
  "icons": {
    "16": "icons/16x16_off.png",
    "48": "icons/48x48_off.png",
    "128": "icons/128x128_off.png"
  },
  "commands": {
    "toggle-limiter": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Toggle ChatGPT lag limiter"
    }
  }
}
